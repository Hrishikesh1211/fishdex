# FishQuest public Expo environment
# Copy this file to `.env.local` for local development.
# Do not commit real `.env*` files.

# local | staging | production
EXPO_PUBLIC_APP_ENV=local

# Public Supabase project URL.
# This value is safe to expose in Expo public runtime config.
EXPO_PUBLIC_SUPABASE_URL=https://sbbotzergiwoxutzbnub.supabase.co

# Public Supabase anon key from Supabase Dashboard > Project Settings > API.
# This key is allowed in mobile apps only when Row Level Security policies are correct.
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Backend/server only. Never prefix this with EXPO_PUBLIC and never import it in mobile code.
# Keep it in Supabase Edge Functions, server jobs, or secure deployment secrets later.
# SUPABASE_SERVICE_ROLE_KEY=never-put-this-in-expo-public-env
